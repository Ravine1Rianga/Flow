# ChaiConnect backend — copy to .env and fill values
# PostgreSQL (Sequelize sync on startup)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chaiconnect
DB_USER=postgres
DB_PASS=your_password_here

# Server
PORT=5000

# Safaricom Daraja (sandbox)
# https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
# Optional: shortcode, passkey, callback URLs for full B2C/C2B in production
# MPESA_SHORTCODE=600000
# MPESA_PASSKEY=your_passkey
# MPESA_CALLBACK_URL=https://your-domain/api/mpesa/callback
# MPESA_RESULT_URL=https://your-domain/api/mpesa/result
